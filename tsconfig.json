{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@THEME": ["src/heart/helpers/config/themeDefinitions.ts"],
      "@/components/*": ["src/heart/layouts/components/*"],
      "@/partials/*": ["src/heart/layouts/partials/*"],
      "@/lib/*": ["src/heart/helpers/lib/*"],
      "@/layouts/*": ["src/heart/layouts/*"],
      "@/utils/*": ["src/heart/helpers/utils/*"],
      "@/types/*": ["src/heart/types/*"],
      "@/config/*": ["src/heart/helpers/config/*"],
      "@/styles/*": ["src/heart/styles/*"],
      "@/*": ["./src/*"]
    },
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ]
  }
}
